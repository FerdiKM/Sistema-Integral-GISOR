@model IEnumerable<SISTEMA_INTEGRAL_GISOR.Models.Incidente>

@{
    ViewData["Title"] = "Mis Reportes";
}

<div class="row justify-content-center">
    <div class="col-12">

        <div class="glass-card">

            <div class="glass-header d-flex justify-content-between align-items-center mb-4 pb-3" style="border-bottom: 1px solid rgba(255,255,255,0.1);">
                <div class="d-flex align-items-center gap-3">
                    <div class="glass-icon" style="width: 50px; height: 50px; margin: 0; font-size: 1.2rem; background: rgba(25, 135, 84, 0.15); color: #75b798;">
                        <i class="fa fa-history"></i>
                    </div>
                    <div>
                        <h4 class="text-bright mb-0">Historial de Mis Alertas</h4>
                        <p class="text-dim mb-0">Seguimiento de tus reportes en tiempo real</p>
                    </div>
                </div>

                <a asp-action="Create" class="btn btn-sm btn-glass-warning text-decoration-none d-flex align-items-center gap-2 px-3 py-2" style="width: auto;">
                    <i class="fa fa-plus"></i> <span class="d-none d-md-inline">Nuevo Reporte</span>
                </a>
            </div>

            <div class="glass-body p-0">
                @if (!Model.Any())
                {
                    <div class="text-center py-5">
                        <div class="mb-3">
                            <i class="fa fa-folder-open fa-4x text-muted opacity-50"></i>
                        </div>
                        <h4 class="text-bright">Sin actividad</h4>
                        <p class="text-dim mb-4">Aún no has realizado ningún reporte.</p>
                        <a asp-action="Create" class="btn btn-glass btn-glass-warning d-inline-flex px-4" style="width: auto;">
                            Reportar un Incidente
                        </a>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-glass align-middle mb-0 w-100">
                            <thead>
                                <tr>
                                    <th class="ps-4 py-3 text-dim">FECHA / HORA</th>
                                    <th class="py-3 text-dim">DESCRIPCIÓN</th>
                                    <th class="text-center py-3 text-dim">ESTADO</th>
                                    <th class="text-end pe-4 py-3 text-dim">ACCIONES</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    // Lógica visual para el estado
                                    bool esPendiente = item.Descripcion.Contains("[PENDIENTE");
                                    string descripcionLimpia = item.Descripcion.Replace("[PENDIENTE APROBACION]", "").Trim();

                                    // Truncar descripción larga
                                    if (descripcionLimpia.Length > 60)
                                    {
                                        descripcionLimpia = descripcionLimpia.Substring(0, 60) + "...";
                                    }

                                    <tr style="border-bottom: 1px solid rgba(255,255,255,0.05);">
                                        <td class="ps-4 py-3">
                                            <div class="d-flex align-items-center text-bright font-monospace">
                                                <i class="fa fa-calendar-alt me-2 text-muted"></i>
                                                @item.FechaHora.ToString("dd/MM/yyyy HH:mm")
                                            </div>
                                        </td>
                                        <td class="py-3">
                                            <span class="text-e0e0e0">@descripcionLimpia</span>
                                        </td>
                                        <td class="text-center py-3">
                                            @if (esPendiente)
                                            {
                                                <span class="badge bg-warning bg-opacity-10 text-warning border border-warning border-opacity-25 px-3 py-2 rounded-pill">
                                                    <i class="fa fa-clock me-1"></i> En Revisión
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 px-3 py-2 rounded-pill">
                                                    <i class="fa fa-check-circle me-1"></i> Aprobado
                                                </span>
                                            }
                                        </td>
                                        <td class="text-end pe-4 py-3">
                                            <a asp-action="Details" asp-route-id="@item.IncidenteId" class="btn btn-sm btn-outline-info rounded-pill px-3 hover-scale">
                                                <i class="fa fa-eye me-1"></i> Ver Detalle
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>

            <div class="p-3 border-top border-secondary border-opacity-25 mt-2">
                <a asp-controller="Home" asp-action="Index" class="btn btn-sm btn-outline-light d-inline-flex align-items-center gap-2 px-3">
                    <i class="fa fa-arrow-left"></i> Volver al Inicio
                </a>
            </div>

        </div>
    </div>
</div>

<style>
    /* Estilos específicos para la tabla glass */
    .table-glass th {
        background-color: rgba(255, 255, 255, 0.03);
        font-weight: 600;
        font-size: 0.75rem;
        letter-spacing: 1px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    }

    .table-glass tr:hover {
        background-color: rgba(255, 255, 255, 0.05);
    }

    .table-glass td {
        color: #e0e0e0;
    }

    .hover-scale:hover {
        transform: scale(1.05);
        transition: 0.2s;
    }
</style>