@model IEnumerable<SISTEMA_INTEGRAL_GISOR.Models.Incidente>

@{
    ViewData["Title"] = "Gestión de Incidentes";
}

<div class="container-fluid mt-4">

    <div class="glass-card mb-4 p-3 d-flex justify-content-between align-items-center">
        <div class="d-flex align-items-center gap-3">
            <a asp-action="Index" class="btn btn-outline-light btn-sm rounded-circle" style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center;">
                <i class="fa fa-arrow-left"></i>
            </a>
            <div>
                <h4 class="text-bright mb-0">Incidentes Pendientes</h4>
                <p class="text-dim mb-0">Cola de moderación en tiempo real</p>
            </div>
        </div>
        <div>
            @if (TempData["MensajeNotificacion"] != null)
            {
                <span class="badge bg-success bg-opacity-75 p-2">@TempData["MensajeNotificacion"]</span>
            }
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="glass-card text-center p-5">
            <i class="fa fa-check-circle fa-4x text-success mb-3 opacity-50"></i>
            <h3 class="text-bright">Bandeja Vacía</h3>
            <p class="text-dim">No hay incidentes que requieran tu atención.</p>
            <a asp-action="Index" class="btn-glass btn-glass-primary mt-3" style="max-width: 200px;">Volver al Menú</a>
        </div>
    }
    else
    {
        <div class="glass-card p-0 overflow-hidden">
            <div class="table-responsive">
                <table class="table table-glass align-middle mb-0">
                    <thead>
                        <tr>
                            <th class="ps-4">Fecha/Hora</th>
                            <th>Descripción</th>
                            <th class="text-center">Evidencia</th>
                            <th class="text-end pe-4">Acciones Operativas</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 text-bright">@item.FechaHora.ToString("dd/MM HH:mm")</td>

                                <td style="max-width: 300px;">
                                    <div class="text-truncate" title="@item.Descripcion">
                                        @item.Descripcion.Replace("[PENDIENTE APROBACION]", "")
                                    </div>
                                    <span class="badge bg-warning text-dark mt-1" style="font-size: 0.7em;">PENDIENTE</span>
                                </td>

                                <td class="text-center">
                                    <a asp-controller="Incidente" asp-action="Details" asp-route-id="@item.IncidenteId" class="btn btn-sm btn-outline-info rounded-pill" target="_blank">
                                        <i class="fa fa-eye me-1"></i> Revisar
                                    </a>
                                </td>

                                <td class="text-end pe-4">
                                    <div class="d-flex justify-content-end gap-2">

                                        <form asp-action="Aprobar" method="post">
                                            <input type="hidden" name="id" value="@item.IncidenteId" />
                                            <button type="submit" class="btn btn-success btn-sm" title="Aprobar y Publicar">
                                                <i class="fa fa-check"></i>
                                            </button>
                                        </form>

                                        <form asp-action="Rechazar" method="post">
                                            <input type="hidden" name="id" value="@item.IncidenteId" />
                                            <button type="submit" class="btn btn-warning btn-sm" onclick="return confirm('¿Rechazar reporte?');" title="Rechazar">
                                                <i class="fa fa-times"></i>
                                            </button>
                                        </form>

                                        <div class="dropdown">
                                            <button class="btn btn-primary btn-sm dropdown-toggle" type="button" data-bs-toggle="dropdown">
                                                <i class="fa fa-headset"></i>
                                            </button>
                                            <ul class="dropdown-menu dropdown-menu-dark shadow">
                                                <li><h6 class="dropdown-header">Notificar a:</h6></li>
                                                <li>
                                                    <form asp-action="NotificarAutoridad" method="post">
                                                        <input type="hidden" name="id" value="@item.IncidenteId" />
                                                        <input type="hidden" name="autoridad" value="POLICIA NACIONAL" />
                                                        <button class="dropdown-item"><i class="fa fa-taxi me-2"></i> Policía</button>
                                                    </form>
                                                </li>
                                                <li>
                                                    <form asp-action="NotificarAutoridad" method="post">
                                                        <input type="hidden" name="id" value="@item.IncidenteId" />
                                                        <input type="hidden" name="autoridad" value="BOMBEROS" />
                                                        <button class="dropdown-item"><i class="fa fa-fire-extinguisher me-2"></i> Bomberos</button>
                                                    </form>
                                                </li>
                                                <li>
                                                    <form asp-action="NotificarAutoridad" method="post">
                                                        <input type="hidden" name="id" value="@item.IncidenteId" />
                                                        <input type="hidden" name="autoridad" value="SAMU" />
                                                        <button class="dropdown-item"><i class="fa fa-ambulance me-2"></i> Ambulancia</button>
                                                    </form>
                                                </li>
                                            </ul>
                                        </div>

                                        <button type="button" class="btn btn-dark btn-sm" data-bs-toggle="modal" data-bs-target="#modalBloqueo-@item.IncidenteId" title="Bloquear Usuario">
                                            <i class="fa fa-ban"></i>
                                        </button>

                                    </div>

                                    <div class="modal fade" id="modalBloqueo-@item.IncidenteId" tabindex="-1" aria-hidden="true">
                                        <div class="modal-dialog">
                                            <div class="modal-content bg-dark text-white border-secondary">
                                                <div class="modal-header border-secondary">
                                                    <h5 class="modal-title text-danger"><i class="fa fa-ban me-2"></i> Bloquear Usuario</h5>
                                                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                                                </div>
                                                <form asp-action="BloquearUsuario" method="post">
                                                    <div class="modal-body">
                                                        <p>¿Bloquear al autor de este reporte?</p>
                                                        <input type="hidden" name="idIncidente" value="@item.IncidenteId" />
                                                        <select name="motivo" class="form-select bg-secondary text-white border-0">
                                                            <option value="Falso">Información Falsa</option>
                                                            <option value="Ofensivo">Contenido Inapropiado</option>
                                                            <option value="Spam">Spam</option>
                                                        </select>
                                                    </div>
                                                    <div class="modal-footer border-secondary">
                                                        <button type="button" class="btn btn-outline-light" data-bs-dismiss="modal">Cancelar</button>
                                                        <button type="submit" class="btn btn-danger">Confirmar</button>
                                                    </div>
                                                </form>
                                            </div>
                                        </div>
                                    </div>

                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>